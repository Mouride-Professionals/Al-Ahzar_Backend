# Public domain (used by Caddy). Example: api.example.com
DOMAIN=api.example.com
CADDY_EMAIL=you@example.com

# Strapi server
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=https://api.example.com
FRONTEND_URL=https://your-frontend.example.com

# Strapi secrets (generate strong values; don't reuse from dev)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=change-me
ADMIN_JWT_SECRET=change-me
JWT_SECRET=change-me

# Database (Postgres in Docker Compose)
DATABASE_CLIENT=postgres
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://strapi:change-me@db:5432/strapi
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Email (Brevo)
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_SENDER_NAME=Al Azhar

# Optional: run config-sync import once on first boot
# STRAPI_CONFIG_SYNC_IMPORT=1
